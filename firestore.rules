rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function workspaceMembers(wsId) {
      return get(/databases/$(database)/documents/workspaces/$(wsId)).data.memberIds;
    }

    function isMember(wsId) {
      return isSignedIn() && request.auth.uid in workspaceMembers(wsId);
    }

    function isOwner(wsId) {
      return isSignedIn() &&
        request.auth.uid == get(/databases/$(database)/documents/workspaces/$(wsId)).data.ownerId;
    }

    // ── USERS ─────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSelf(userId);
      allow update: if isSelf(userId);
      allow delete: if isSelf(userId);
    }

    // ── WORKSPACES ────────────────────────────────────────────────────
    match /workspaces/{wsId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.memberIds;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.ownerId
                    && request.auth.uid in request.resource.data.memberIds;
      allow update: if isSignedIn() && request.auth.uid in resource.data.memberIds;
      allow delete: if isOwner(wsId);

      // ── TASKS (subcollection) ───────────────────────────────────────
      match /tasks/{taskId} {
        allow read, create, update, delete: if isMember(wsId);
      }

      // ── ASSIGNMENT RUNS (subcollection) ─────────────────────────────
      match /assignmentRuns/{runId} {
        allow read: if isMember(wsId);
        allow create, update: if isMember(wsId);
        allow delete: if isOwner(wsId);
      }
    }

    // ── INVITES ───────────────────────────────────────────────────────
    match /invites/{code} {
      // Anyone signed in can read an invite (to see workspace name on /join page)
      allow read: if isSignedIn();
      // Only workspace members can create invites for their workspace
      allow create: if isSignedIn() &&
        request.auth.uid == request.resource.data.createdBy &&
        request.auth.uid in workspaceMembers(request.resource.data.workspaceId);
      // Redeeming: signed-in users can increment usedCount and append themselves
      allow update: if isSignedIn() &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['usedCount', 'usedBy']);
      // Only creator can delete (revoke)
      allow delete: if isSignedIn() && request.auth.uid == resource.data.createdBy;
    }
  }
}
